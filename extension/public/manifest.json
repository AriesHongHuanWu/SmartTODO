{
  "manifest_version": 3,
  "name": "SmartTODO",
  "version": "2.0",
  "description": "AI-powered task extraction from any website",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://*.vercel.app/*",
      "https://*.smarttodo.com/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartTODO"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ]
}
